{
    "configurations": [
        {
            "name": "Win32 - MSYS2 UCRT64 (g++)",
            "includePath": [
                "${workspaceFolder}/**",
                "C:/msys64/ucrt64/include/**",
                "C:/msys64/ucrt64/include/c++/**"
            ],
            "defines": [
                "_DEBUG",
                "UNICODE",
                "_UNICODE"
            ],
            "compilerPath": "C:/msys64/ucrt64/bin/g++.exe",
            "cStandard": "c99",
            "cppStandard": "c++98",
            "intelliSenseMode": "windows-gcc-x64",
            "compilerArgs": [
                "-std=c++98",
                "-Wall"
            ]
        }
    ],
    "version": 4
}
